# Local development secrets for `wrangler dev`.
# Copy this file to .dev.vars (gitignored) and fill in what you have.
# Production secrets are NOT set here — they go in Cloudflare (see SETUP.md section 4).

SESSION_SECRET=dev-only-secret-not-for-production
RESEND_KEY=
MAIL_FROM=Fuel Protocol <onboarding@resend.dev>
FS_KEY=
FS_SECRET=
ALLOW_DEV_LINK=1
